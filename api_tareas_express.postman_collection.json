{
  "info": {
    "name": "api_tareas_express",
    "description": "REST API for task management with JWT authentication, CORS, and rate limiting.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "taskId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Obtain a JWT token. Returns `token` and `expiresIn`. Copy the token into the `authToken` collection variable to authenticate subsequent requests."
          },
          "response": [
            {
              "name": "200 OK – JWT issued",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"expiresIn\": \"1h\"\n}"
            },
            {
              "name": "401 Unauthorized – invalid credentials",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Unauthorized\",\n  \"message\": \"Invalid credentials\"\n}"
            },
            {
              "name": "422 Unprocessable Entity – validation error",
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"ValidationError\",\n  \"message\": \"\\\"username\\\" is required\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "GET List Tasks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks?page=1&limit=10&status=pending&priority=medium&search=&sortBy=createdAt&sortOrder=desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (default: 1)"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Items per page (default: 10)"
                },
                {
                  "key": "status",
                  "value": "pending",
                  "description": "Filter by status: pending | in_progress | completed",
                  "disabled": true
                },
                {
                  "key": "priority",
                  "value": "medium",
                  "description": "Filter by priority: low | medium | high",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "",
                  "description": "Full-text search on title/description",
                  "disabled": true
                },
                {
                  "key": "sortBy",
                  "value": "createdAt",
                  "description": "Sort field: createdAt | dueDate | priority (default: createdAt)"
                },
                {
                  "key": "sortOrder",
                  "value": "desc",
                  "description": "Sort direction: asc | desc (default: desc)"
                }
              ]
            },
            "description": "Returns a paginated list of tasks belonging to the authenticated user. All query parameters are optional."
          },
          "response": [
            {
              "name": "200 OK – paginated list",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"data\": [],\n  \"total\": 0,\n  \"page\": 1,\n  \"limit\": 10\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Unauthorized\",\n  \"message\": \"No token provided\"\n}"
            }
          ]
        },
        {
          "name": "POST Create Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Buy groceries\",\n  \"description\": \"Milk, eggs, bread\",\n  \"status\": \"pending\",\n  \"priority\": \"medium\",\n  \"dueDate\": \"2026-04-15T00:00:00.000Z\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "Creates a new task for the authenticated user. Only `title` is required."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"_id\": \"663a1b2c4f1a2b3c4d5e6f70\",\n  \"title\": \"Buy groceries\",\n  \"description\": \"Milk, eggs, bread\",\n  \"status\": \"pending\",\n  \"priority\": \"medium\",\n  \"dueDate\": \"2026-04-15T00:00:00.000Z\",\n  \"createdAt\": \"2026-04-10T12:00:00.000Z\",\n  \"updatedAt\": \"2026-04-10T12:00:00.000Z\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Unauthorized\",\n  \"message\": \"No token provided\"\n}"
            },
            {
              "name": "422 Unprocessable Entity – validation error",
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"ValidationError\",\n  \"message\": \"\\\"title\\\" is required\"\n}"
            }
          ]
        },
        {
          "name": "GET Task by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{taskId}}",
                  "description": "MongoDB ObjectId of the task"
                }
              ]
            },
            "description": "Returns a single task by its ID. The task must belong to the authenticated user."
          },
          "response": [
            {
              "name": "200 OK – task found",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"_id\": \"663a1b2c4f1a2b3c4d5e6f70\",\n  \"title\": \"Buy groceries\",\n  \"description\": \"Milk, eggs, bread\",\n  \"status\": \"pending\",\n  \"priority\": \"medium\",\n  \"dueDate\": \"2026-04-15T00:00:00.000Z\",\n  \"createdAt\": \"2026-04-10T12:00:00.000Z\",\n  \"updatedAt\": \"2026-04-10T12:00:00.000Z\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Unauthorized\",\n  \"message\": \"No token provided\"\n}"
            },
            {
              "name": "403 Forbidden",
              "status": "Forbidden",
              "code": 403,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Forbidden\",\n  \"message\": \"Access denied\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"NotFound\",\n  \"message\": \"Task not found\"\n}"
            }
          ]
        },
        {
          "name": "PUT Replace Task",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Buy groceries (updated)\",\n  \"description\": \"Milk, eggs, bread, butter\",\n  \"status\": \"in_progress\",\n  \"priority\": \"high\",\n  \"dueDate\": \"2026-04-20T00:00:00.000Z\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{taskId}}",
                  "description": "MongoDB ObjectId of the task"
                }
              ]
            },
            "description": "Fully replaces a task (all fields). The task must belong to the authenticated user."
          },
          "response": [
            {
              "name": "200 OK – task replaced",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"_id\": \"663a1b2c4f1a2b3c4d5e6f70\",\n  \"title\": \"Buy groceries (updated)\",\n  \"description\": \"Milk, eggs, bread, butter\",\n  \"status\": \"in_progress\",\n  \"priority\": \"high\",\n  \"dueDate\": \"2026-04-20T00:00:00.000Z\",\n  \"createdAt\": \"2026-04-10T12:00:00.000Z\",\n  \"updatedAt\": \"2026-04-10T13:00:00.000Z\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Unauthorized\",\n  \"message\": \"No token provided\"\n}"
            },
            {
              "name": "403 Forbidden",
              "status": "Forbidden",
              "code": 403,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Forbidden\",\n  \"message\": \"Access denied\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"NotFound\",\n  \"message\": \"Task not found\"\n}"
            },
            {
              "name": "422 Unprocessable Entity – validation error",
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"ValidationError\",\n  \"message\": \"\\\"title\\\" is required\"\n}"
            }
          ]
        },
        {
          "name": "PATCH Update Task Fields",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{taskId}}",
                  "description": "MongoDB ObjectId of the task"
                }
              ]
            },
            "description": "Partially updates a task — only the provided fields are changed. The task must belong to the authenticated user."
          },
          "response": [
            {
              "name": "200 OK – task updated",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"_id\": \"663a1b2c4f1a2b3c4d5e6f70\",\n  \"title\": \"Buy groceries\",\n  \"status\": \"completed\",\n  \"priority\": \"medium\",\n  \"createdAt\": \"2026-04-10T12:00:00.000Z\",\n  \"updatedAt\": \"2026-04-10T14:00:00.000Z\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Unauthorized\",\n  \"message\": \"No token provided\"\n}"
            },
            {
              "name": "403 Forbidden",
              "status": "Forbidden",
              "code": 403,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Forbidden\",\n  \"message\": \"Access denied\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"NotFound\",\n  \"message\": \"Task not found\"\n}"
            },
            {
              "name": "422 Unprocessable Entity – validation error",
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"ValidationError\",\n  \"message\": \"\\\"status\\\" must be one of [pending, in_progress, completed]\"\n}"
            }
          ]
        },
        {
          "name": "DELETE Task",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{taskId}}",
                  "description": "MongoDB ObjectId of the task"
                }
              ]
            },
            "description": "Permanently deletes a task. Returns 204 No Content on success. The task must belong to the authenticated user."
          },
          "response": [
            {
              "name": "204 No Content – deleted",
              "status": "No Content",
              "code": 204,
              "header": [],
              "body": ""
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Unauthorized\",\n  \"message\": \"No token provided\"\n}"
            },
            {
              "name": "403 Forbidden",
              "status": "Forbidden",
              "code": 403,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Forbidden\",\n  \"message\": \"Access denied\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"NotFound\",\n  \"message\": \"Task not found\"\n}"
            }
          ]
        }
      ]
    }
  ]
}
